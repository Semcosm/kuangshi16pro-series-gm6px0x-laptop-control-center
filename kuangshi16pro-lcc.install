post_install() {
  cat <<'EOF'
kuangshi16pro-lcc installed.

The lccd daemon is not enabled by default on Arch.
Enable it manually if you want a persistent system service:
  systemctl enable --now lccd.service

The package also ships D-Bus activation metadata, so one-shot activation still
depends on a working system bus and polkit service.
EOF
}

post_upgrade() {
  post_install
}
